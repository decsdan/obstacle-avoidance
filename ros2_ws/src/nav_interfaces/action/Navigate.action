# Goal
geometry_msgs/PoseStamped goal
string global_planner                   # "a_star" | "d_star" | "jps" | "rrt_star" | "fm2"
string local_planner                    # "dwa" | "mppi" | "rl_policy"
float64 global_budget                   # PlanPath budget; 0 = planner default
string scenario_id                      # Optional; correlates the run with a scenario record
---
# Result
bool success
string terminal_outcome                 # "reached" | "collision" | "timeout" | "stuck" | "cancelled" | "failed"
float64 total_distance
float64 total_time
uint32 replan_count
---
# Feedback
float64 distance_to_goal
float64 distance_traveled
float64 elapsed_time
string nav_state                        # "planning" | "following" | "replanning" | "recovering"
geometry_msgs/Pose current_pose
geometry_msgs/Twist current_velocity
